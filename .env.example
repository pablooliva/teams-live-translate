# Copy to .env and fill in. Load it with: uv run --env-file .env teams-live-translate

# Google AI Studio API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Target language (BCP-47): de=German, es=Spanish, fr=French, pl=Polish, ...
TARGET_LANGUAGE=de

# Source language hint — informational only; the model auto-detects. Leave blank.
SOURCE_LANGUAGE=

# Audio devices (name substring or numeric index from --list-devices).
# INPUT_DEVICE  = the virtual device Teams outputs to
#                 macOS: "BlackHole"   Windows: "CABLE Output"
# OUTPUT_DEVICE = your real headphones/speakers
INPUT_DEVICE=BlackHole
OUTPUT_DEVICE=

# Output even when speech is already in the target language (1=on, 0=off)
ECHO_TARGET=1
